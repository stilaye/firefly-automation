{
  "name": "firefly",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "test": "npx playwright test",
    "test:ci": "CI=true npx playwright test",
    "test:headed": "npx playwright test --headed",
    "test:debug": "npx playwright test --debug",
    "test:ui": "npx playwright test --ui",
    "test:chromium": "npx playwright test --project=chromium",
    "test:firefox": "npx playwright test --project=firefox",
    "test:webkit": "npx playwright test --project=webkit",
    "test:cross-browser": "npx playwright test --project=chromium --project=firefox --project=webkit",
    "test:smoke": "npx playwright test --grep @smoke",
    "test:critical": "npx playwright test --grep @critical",
    "test:regression": "npx playwright test --grep @regression",
    "test:generation": "npx playwright test --grep @generation",
    "test:editing": "npx playwright test --grep @editing",
    "test:projects": "npx playwright test --grep @projects",
    "test:auth": "npx playwright test --grep @auth",
    "test:visual": "npx playwright test tests/visual.regression.spec.ts",
    "test:api": "npx playwright test --grep @api",
    "test:abbott": "npx playwright test --project=abbott",
    "test:abbott:visual": "npx playwright test --project=abbott --grep @visual",
    "test:abbott:a11y": "npx playwright test --project=abbott --grep @accessibility",
    "report:allure": "allure generate ./allure-results -o ./allure-report --clean",
    "show-report:allure": "allure open ./allure-report",
    "report:show": "npx playwright show-report",
    "report:analytics": "node -e \"const d=require('./test-results/analytics.json');const r=d.runs[d.runs.length-1];console.log('Last run:',r.summary,'Duration:',Math.round(r.duration/1000)+'s');if(Object.keys(d.flakyTests).length)console.log('Flaky tests:',d.flakyTests)\"",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write ."
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.3",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.2.3",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "allure-commandline": "^2.36.0",
    "allure-playwright": "^3.4.5",
    "dotenv": "^17.3.1",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsdoc": "^62.5.5",
    "eslint-plugin-playwright": "^2.5.1",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "agentation": "^2.2.1"
  }
}
